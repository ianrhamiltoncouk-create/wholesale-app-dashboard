{% comment %}
  Cart Abandonment Recovery & Quote Request (App Embed Version with Auto-Injection)
  Automatically triggers exit intent site-wide for all visitors and injects a recovery button on the cart page.
  Helps merchants capture abandoned carts by offering to email them a checkout link.
  Zero code editing required from the merchant.
  Schema optimized for App Embed limitations (max 6 settings).
{% endcomment %}

<!-- Modal Backdrop & Card HTML (Renders globally in body) -->
{{ 'storefront-suite.css' | asset_url | stylesheet_tag }}
<div class="cart-quote-section" id="cart-quote-{{ block.id }}" data-block-id="{{ block.id }}">
  <!-- Modal Template -->
  <div class="quote-modal-backdrop" id="quoteModal">
    <div class="quote-modal-card">
      <button type="button" class="quote-modal-close" onclick="closeCartQuoteModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="close-icon">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="quote-modal-grid">
        <!-- Left Side: Cart Items Summary -->
        <div class="quote-modal-cart-summary">
          <h4 class="summary-title">Your Cart Items</h4>
          <div class="summary-items-list" id="quoteCartItemsList">
            <p class="summary-loading">Loading your cart...</p>
          </div>
          <div class="summary-total-row">
            <span>Cart Subtotal</span>
            <strong id="quoteCartSubtotal">$0.00</strong>
          </div>
        </div>

        <!-- Right Side: Contact & Details Form -->
        <div class="quote-modal-form-wrapper">
          <div class="form-header">
            <span class="form-tag">Cart Recovery</span>
            <h3 class="form-title">{{ block.settings.heading | default: "Save Your Cart & Checkout Later" | escape }}</h3>
            <p class="form-subheading">{{ block.settings.subheading | default: "Don't lose your items! Enter your email and we will send you a secure link to recover your cart and complete checkout whenever you are ready." | escape }}</p>
          </div>

          <!-- Success Screen -->
          <div class="quote-success-screen" style="display: none;" id="quoteSuccessScreen">
            <div class="success-checkmark-wrapper">
              <svg viewBox="0 0 20 20" fill="currentColor" class="success-icon">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <h4>Cart Link Emailed!</h4>
            <p>We've successfully received your cart details. Check your inbox shortly for your personalized recovery email and secure checkout link.</p>
            <button type="button" class="quote-success-close-btn" onclick="closeCartQuoteModal()">Close Window</button>
          </div>

          <!-- Contact Form -->
          {% form 'contact', id: 'quoteRequestForm', class: 'quote-form' %}
            {% if form.posted_successfully? %}
              <script>
                document.addEventListener("DOMContentLoaded", function() {
                  document.getElementById('quoteRequestForm').style.display = 'none';
                  document.getElementById('quoteSuccessScreen').style.display = 'flex';
                });
              </script>
            {% endif %}

            <input type="hidden" name="contact[form_name]" value="Cart Recovery Request">
            <textarea name="contact[body]" id="quoteHiddenCartDetails" style="display: none;" required></textarea>

            <div class="field-group">
              <label for="quote-email">Email Address *</label>
              <input type="email" 
                     id="quote-email" 
                     name="contact[email]" 
                     class="field-input" 
                     placeholder="email@example.com" 
                     value="{% if customer %}{{ customer.email }}{% endif %}" 
                     required>
            </div>

            <div class="field-row">
              <div class="field-group">
                <label for="quote-name">Full Name</label>
                <input type="text" 
                       id="quote-name" 
                       name="contact[name]" 
                       class="field-input" 
                       placeholder="John Doe" 
                       value="{% if customer %}{{ customer.name }}{% endif %}">
              </div>
              <div class="field-group">
                <label for="quote-company">Company (Optional)</label>
                <input type="text" 
                       id="quote-company" 
                       name="contact[company]" 
                       class="field-input" 
                       placeholder="Acme Corp">
              </div>
            </div>

            <div class="field-group">
              <label for="quote-note">Add notes or special requests (Optional)</label>
              <textarea id="quote-note" 
                        name="contact[merchant_note]" 
                        class="field-input field-textarea" 
                        placeholder="e.g. Please calculate shipping to..."></textarea>
            </div>

            <button type="submit" class="quote-submit-btn" id="quoteSubmitBtn">
              <span class="btn-text">Email Me My Cart Link</span>
              <span class="btn-spinner" style="display: none;"></span>
            </button>
          {% endform %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let hasShownExitIntent = false;

  function openCartQuoteModal() {
    const backdrop = document.getElementById('quoteModal');
    if (backdrop) {
      backdrop.classList.add('is-open');
      loadQuoteCartData();
    }
  }

  function closeCartQuoteModal() {
    const backdrop = document.getElementById('quoteModal');
    if (backdrop) {
      backdrop.classList.remove('is-open');
    }
  }

  function loadQuoteCartData() {
    const listContainer = document.getElementById('quoteCartItemsList');
    const subtotalEl = document.getElementById('quoteCartSubtotal');
    const hiddenBodyField = document.getElementById('quoteHiddenCartDetails');
    
    if (!listContainer) return;

    fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        if (!cart.items || cart.items.length === 0) {
          listContainer.innerHTML = '<p class="summary-loading">Your cart is empty.</p>';
          if (subtotalEl) subtotalEl.textContent = formatCartMoney(0);
          return;
        }

        let itemsHtml = '';
        let plaintextList = 'Abandoned Cart Summary (Checkout Link Request):\n\n';

        cart.items.forEach(item => {
          const itemImg = item.image ? item.image : 'https://cdn.shopify.com/s/images/admin/no-image-large.gif';
          const optionText = item.variant_options && item.variant_options.length > 0 && item.variant_options[0] !== 'Default Title' 
            ? ` (${item.variant_options.join(', ')})` 
            : '';

          itemsHtml += `
            <div class="quote-cart-item">
              <img src="${itemImg}" alt="${item.title}" class="item-img">
              <div class="item-info">
                <p class="item-name">${item.product_title}</p>
                <span class="item-meta">Qty: ${item.quantity} ${optionText}</span>
              </div>
              <span class="item-price">${formatCartMoney(item.line_price)}</span>
            </div>
          `;

          plaintextList += `- ${item.quantity}x ${item.product_title} ${optionText} (Variant ID: ${item.variant_id}) - Unit Price: ${formatCartMoney(item.price)} (Total: ${formatCartMoney(item.line_price)})\n`;
        });

        plaintextList += `\nCart Total: ${formatCartMoney(cart.total_price)}`;
        
        listContainer.innerHTML = itemsHtml;
        if (subtotalEl) subtotalEl.textContent = formatCartMoney(cart.total_price);
        if (hiddenBodyField) hiddenBodyField.value = plaintextList;
      })
      .catch(err => {
        console.error('Error loading cart preview', err);
        listContainer.innerHTML = '<p class="summary-loading">Error loading cart items.</p>';
      });
  }

  function formatCartMoney(cents) {
    const amount = (cents / 100.0).toFixed(2);
    const shopCurrencySymbol = '{{ cart.currency.symbol }}' || '$';
    return `${shopCurrencySymbol}${amount}`;
  }

  document.addEventListener("DOMContentLoaded", function() {
    const form = document.getElementById('quoteRequestForm');
    const successScreen = document.getElementById('quoteSuccessScreen');
    const webhookUrl = '{{ block.settings.webhook_url | escape }}';
    
    const isCartPage = window.location.pathname === '/cart' || window.location.pathname.endsWith('/cart');
    const enableCartBtn = {{ block.settings.enable_cart_page_button | json }};

    let cartItemCount = {{ cart.item_count | default: 0 }};
    
    function checkAndResetSessionLock() {
      const storedCount = parseInt(sessionStorage.getItem('last_cart_count') || '0', 10);
      if (cartItemCount > storedCount) {
        // Cart count increased (either via reload or AJAX)! Clear the lock and memory flag.
        sessionStorage.removeItem('quote_modal_shown');
        hasShownExitIntent = false;
      }
      sessionStorage.setItem('last_cart_count', cartItemCount.toString());
    }

    function refreshCartCount() {
      fetch('/cart.js')
        .then(res => res.json())
        .then(cart => {
          cartItemCount = cart.item_count;
          checkAndResetSessionLock();
        })
        .catch(err => console.error('Error fetching background cart count', err));
    }

    // Run initial sync on load
    checkAndResetSessionLock();
    refreshCartCount();

    // Intercept AJAX add-to-cart operations (handles cart drawers, slide-out carts)
    const nativeFetch = window.fetch;
    window.fetch = function() {
      return nativeFetch.apply(this, arguments).then(response => {
        const url = arguments[0];
        if (typeof url === 'string' && (url.includes('/cart/add') || url.includes('/cart/change') || url.includes('/cart/clear') || url.includes('/cart/update'))) {
          setTimeout(refreshCartCount, 400);
        }
        return response;
      });
    };

    if (enableCartBtn && isCartPage) {
      const checkoutBtnSelectors = [
        'button[name="checkout"]',
        '.cart__checkout-button',
        '#checkout',
        '[name="checkout"]'
      ];
      
      let checkoutBtn = null;
      for (let selector of checkoutBtnSelectors) {
        checkoutBtn = document.querySelector(selector);
        if (checkoutBtn) break;
      }

      if (checkoutBtn && !document.querySelector('.cart-quote-trigger-btn')) {
        const triggerBtn = document.createElement('button');
        triggerBtn.type = 'button';
        triggerBtn.className = 'cart-quote-trigger-btn';
        triggerBtn.innerHTML = `
          <svg viewBox="0 0 20 20" fill="currentColor" class="btn-icon">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
          </svg>
          ${"{{ block.settings.cart_button_text }}" ? "{{ block.settings.cart_button_text | escape }}" : "Email Me My Cart Link"}
        `;
        triggerBtn.addEventListener('click', openCartQuoteModal);
        
        checkoutBtn.parentNode.insertBefore(triggerBtn, checkoutBtn.nextSibling);
      }
    }

    {% if block.settings.enable_exit_intent %}
      const isDesignMode = window.Shopify && window.Shopify.designMode;

      // 1. Intercept browser tab/window close button
      window.addEventListener('beforeunload', function(e) {
        const isLocked = sessionStorage.getItem('quote_modal_shown');
        if (cartItemCount > 0 && (isDesignMode || !isLocked) && !hasShownExitIntent) {
          e.preventDefault();
          
          setTimeout(function() {
            hasShownExitIntent = true;
            sessionStorage.setItem('quote_modal_shown', 'true');
            openCartQuoteModal();
          }, 100);

          e.returnValue = 'You have items in your cart! Would you like us to email you a checkout link?';
          return e.returnValue;
        }
      });

      // 2. Always listen to exit intent, but evaluate the session lock dynamically inside the event
      document.addEventListener('mouseleave', function(e) {
        const isLocked = sessionStorage.getItem('quote_modal_shown');
        if (cartItemCount > 0 && (isDesignMode || !isLocked) && !hasShownExitIntent) {
          hasShownExitIntent = true;
          sessionStorage.setItem('quote_modal_shown', 'true');
          openCartQuoteModal();
        }
      });

      document.addEventListener('mouseout', function(e) {
        const isLocked = sessionStorage.getItem('quote_modal_shown');
        if (e.clientY < 20 && cartItemCount > 0 && (isDesignMode || !isLocked) && !hasShownExitIntent) {
          hasShownExitIntent = true;
          sessionStorage.setItem('quote_modal_shown', 'true');
          openCartQuoteModal();
        }
      });
    {% endif %}

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const submitBtn = document.getElementById('quoteSubmitBtn');
        const btnText = submitBtn.querySelector('.btn-text');
        const btnSpinner = submitBtn.querySelector('.btn-spinner');
        
        if (btnText && btnSpinner) {
          btnText.style.display = 'none';
          btnSpinner.style.display = 'inline-block';
        }
        submitBtn.disabled = true;

        const email = document.getElementById('quote-email').value;
        const name = document.getElementById('quote-name').value;
        const company = document.getElementById('quote-company').value;
        const note = document.getElementById('quote-note').value;

        if (webhookUrl && webhookUrl.trim() !== '') {
          fetch('/cart.js')
            .then(res => res.json())
            .then(cart => {
              const payload = {
                email: email,
                name: name,
                company: company,
                note: note,
                cart_items: cart.items.map(item => ({
                  variant_id: item.variant_id,
                  quantity: item.quantity,
                  product_title: item.product_title,
                  variant_title: item.variant_title,
                  price: item.price / 100.0,
                  sku: item.sku
                })),
                cart_total: cart.total_price / 100.0,
                shop_domain: Shopify.shop
              };

              return fetch(webhookUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
            })
            .then(() => {
              form.style.display = 'none';
              successScreen.style.display = 'flex';
            })
            .catch(error => {
              console.error('Webhook failed, trying Shopify form fallback', error);
              submitNativeForm(form);
            });
        } else {
          submitNativeForm(form);
        }
      });
    }

    function submitNativeForm(formElement) {
      const formData = new FormData(formElement);
      fetch(formElement.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'text/html' }
      })
      .then(() => {
        formElement.style.display = 'none';
        successScreen.style.display = 'flex';
      })
      .catch(err => {
        console.error('Shopify form AJAX failed, submitting normally', err);
        formElement.submit();
      });
    }
  });
</script>

{% schema %}
{
  "name": "Cart Auto-Recovery",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_exit_intent",
      "label": "Enable Exit-Intent Trigger",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_cart_page_button",
      "label": "Enable Cart Button Auto-Inject",
      "default": true
    },
    {
      "type": "text",
      "id": "cart_button_text",
      "label": "Cart Button Label",
      "default": "Email Me My Cart Link"
    },
    {
      "type": "text",
      "id": "webhook_url",
      "label": "Webhook URL (Optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Modal Heading",
      "default": "Save Your Cart & Checkout Later"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Modal Subheading",
      "default": "Don't lose your items! Enter your email and we will send you a secure link to recover your cart and complete checkout whenever you are ready."
    }
  ]
}
{% endschema %}
