{% comment %}
  Wholesale Bulk Pricing (App Embed version with Auto-Injection)
  Automatically injects the wholesale pricing grid onto product pages above the product form.
  Zero code editing required from the merchant.
  Schema optimized for App Embed limitations (max 6 settings).
{% endcomment %}

{% if request.page_type == 'product' %}
  {%- liquid
    assign show_widget = false
    if block.settings.only_wholesale_tagged == false and customer
      assign show_widget = true
    elsif block.settings.only_wholesale_tagged and customer
      for tag in customer.tags
        assign downcased_tag = tag | downcase
        assign target_tag = block.settings.custom_tag | downcase
        if downcased_tag == target_tag
          assign show_widget = true
          break
        endif
      endfor
    endif

    assign current_variant = product.selected_or_first_available_variant
  -%}

  <!-- Embed Product JSON for JS variant matching -->
  <script id="wholesale-product-json-{{ block.id }}" type="application/json">
    {{ product | json }}
  </script>

  <script>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      injectWholesalePricingWidget();
    });

    function injectWholesalePricingWidget() {
      // Find the target element (usually the add to cart form)
      const targetSelector = "form[action*='/cart/add']";
      const targetElement = document.querySelector(targetSelector);
      
      if (!targetElement) {
        const fallbacks = ['.product-form', '.product-single__meta', '.product-info'];
        let fallbackElement = null;
        for (let selector of fallbacks) {
          fallbackElement = document.querySelector(selector);
          if (fallbackElement) break;
        }
        if (fallbackElement) {
          insertWidget(fallbackElement);
        }
      } else {
        insertWidget(targetElement);
      }
    }

    function insertWidget(target) {
      if (document.getElementById('wholesale-widget-{{ block.id }}')) return;

      const widgetContainer = document.createElement('div');
      widgetContainer.id = 'wholesale-widget-{{ block.id }}';
      widgetContainer.className = 'wholesale-widget-container-embed';

      target.parentNode.insertBefore(widgetContainer, target);

      const showWidget = {{ show_widget | json }};
      const formattedBasePrice = formatMoney({{ current_variant.price }});

      if (showWidget) {
        widgetContainer.innerHTML = `
          <div class="wholesale-card wholesale-card--logged-in">
            <div class="wholesale-header">
              <div class="wholesale-title-wrapper">
                <span class="wholesale-badge-glow">Wholesale Exclusive</span>
                <h3 class="wholesale-title">Wholesale Bulk Pricing</h3>
              </div>
              <p class="wholesale-subheading">
                Add more to your order and unlock tiered discount rates!
              </p>
            </div>

            <div class="wholesale-tiers-grid style-modern_grid">
              <div class="wholesale-tier-card active" data-min-qty="1" data-discount-value="0" data-discount-type="percentage">
                <div class="wholesale-tier-qty">1 - ${ ({{ block.settings.tier_1_qty | default: 5 }} - 1) } items</div>
                <div class="wholesale-tier-price" data-base-price="{{ current_variant.price }}">${formattedBasePrice}</div>
                <div class="wholesale-tier-discount">Regular Price</div>
                <div class="wholesale-tier-status"><span class="status-dot"></span> Current</div>
              </div>

              ${ {{ block.settings.tier_1_qty | default: 0 }} > 0 ? `
                <div class="wholesale-tier-card" 
                     data-min-qty="{{ block.settings.tier_1_qty }}" 
                     ${ {{ block.settings.tier_2_qty | default: 0 }} > 0 ? `data-max-qty="${ ({{ block.settings.tier_2_qty | default: 10 }} - 1) }"` : '' }
                     data-discount-value="{{ block.settings.tier_1_value | default: 10 }}" 
                     data-discount-type="percentage"
                     data-discount-code="BULK5">
                  <div class="wholesale-tier-qty">
                    ${ {{ block.settings.tier_2_qty | default: 0 }} > 0 ? `{{ block.settings.tier_1_qty }} - ${ ({{ block.settings.tier_2_qty | default: 10 }} - 1) }` : '{{ block.settings.tier_1_qty }}+' } items
                  </div>
                  <div class="wholesale-tier-price" data-base-price="{{ current_variant.price }}">Calculating...</div>
                  <div class="wholesale-tier-discount">
                    {{ block.settings.tier_1_value | default: 10 }}% OFF
                  </div>
                  <div class="wholesale-tier-status"><span class="status-dot"></span> Select</div>
                </div>
              ` : '' }

              ${ {{ block.settings.tier_2_qty | default: 0 }} > 0 ? `
                <div class="wholesale-tier-card" 
                     data-min-qty="{{ block.settings.tier_2_qty }}" 
                     data-discount-value="{{ block.settings.tier_2_value | default: 20 }}" 
                     data-discount-type="percentage"
                     data-discount-code="BULK10">
                  <div class="wholesale-tier-qty">
                    {{ block.settings.tier_2_qty }}+ items
                  </div>
                  <div class="wholesale-tier-price" data-base-price="{{ current_variant.price }}">Calculating...</div>
                  <div class="wholesale-tier-discount">
                    {{ block.settings.tier_2_value | default: 20 }}% OFF
                  </div>
                  <div class="wholesale-tier-status"><span class="status-dot"></span> Select</div>
                </div>
              ` : '' }
            </div>

            <div class="wholesale-progress-wrapper" style="display: none;">
              <div class="wholesale-progress-text">
                <span>Your progress</span>
                <span class="wholesale-progress-hint">Add more to save</span>
              </div>
              <div class="wholesale-progress-bar-bg">
                <div class="wholesale-progress-bar-fill" style="width: 0%"></div>
              </div>
            </div>

            <div class="wholesale-calculator">
              <div class="calc-row">
                <span class="calc-label">Selected Quantity</span>
                <span class="calc-val" id="calc-qty-display">1 item</span>
              </div>
              <div class="calc-row">
                <span class="calc-label">Unit Price</span>
                <span class="calc-val price-discounted" id="calc-unit-price">${formattedBasePrice}</span>
              </div>
              <div class="calc-row total-row">
                <span class="calc-label">Total Price</span>
                <div class="calc-total-wrapper">
                  <span class="calc-val price-original" id="calc-original-total" style="display: none;"></span>
                  <span class="calc-val price-final" id="calc-final-total">${formattedBasePrice}</span>
                </div>
              </div>
              <div class="calc-savings-badge" id="calc-savings-container" style="display: none;">
                <svg viewBox="0 0 20 20" fill="currentColor" class="savings-icon">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span>You are saving <strong id="calc-savings-amount">$0.00</strong> on this bulk order!</span>
              </div>
            </div>

            <div class="wholesale-footer-note">
              * Discount is automatically applied in your cart and at checkout.
            </div>
          </div>
        `;
      } else {
        widgetContainer.innerHTML = `
          <div class="wholesale-card wholesale-card--logged-out">
            <div class="lock-icon-wrapper">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lock-icon">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            </div>
            <h3 class="wholesale-logged-out-title">Wholesale Pricing Available</h3>
            <p class="wholesale-logged-out-text">Log in to your wholesale account to view bulk pricing tiers and unlock exclusive savings.</p>
            <a href="{{ routes.account_login_url }}?return_to=${encodeURIComponent(window.location.pathname)}" class="wholesale-login-btn">
              Log In to Account
            </a>
            <div class="wholesale-register-prompt">
              Don't have a wholesale account? <a href="{{ routes.account_register_url }}">Apply here</a>.
            </div>
          </div>
        `;
      }

      initWholesaleWidget('{{ block.id }}');
    }

    function initWholesaleWidget(blockId) {
      const container = document.getElementById(`wholesale-widget-${blockId}`);
      if (!container) return;

      const loggedInCard = container.querySelector('.wholesale-card--logged-in');
      if (!loggedInCard) return;

      const productJsonElement = document.getElementById(`wholesale-product-json-${blockId}`);
      if (!productJsonElement) return;
      const productData = JSON.parse(productJsonElement.textContent);
      
      const qtyInputSelectors = [
        'input[name="quantity"]',
        '.quantity__input',
        '.product-form__input--quantity input',
        'form[action*="/cart/add"] input[type="number"][name="quantity"]'
      ];
      let qtyInput = null;
      for (let selector of qtyInputSelectors) {
        qtyInput = document.querySelector(selector);
        if (qtyInput) break;
      }

      const variantInputSelectors = [
        'select[name="id"]',
        'input[name="id"]',
        '[name="id"]',
        'variant-selects select',
        'variant-radios input[type="radio"]:checked'
      ];
      
      function getSelectedVariantId() {
        for (let selector of variantInputSelectors) {
          const el = document.querySelector(selector);
          if (el) return el.value;
        }
        return productData.variants[0].id;
      }

      function getSelectedVariant(variantId) {
        return productData.variants.find(v => v.id.toString() === variantId.toString()) || productData.variants[0];
      }

      let currentlyAppliedCode = '';

      function updateWidget() {
        const activeVariantId = getSelectedVariantId();
        const variant = getSelectedVariant(activeVariantId);
        const currentPrice = variant.price;

        const tierCards = container.querySelectorAll('.wholesale-tier-card');
        let pricingTiers = [];

        tierCards.forEach(card => {
          const minQty = parseInt(card.dataset.minQty, 10);
          const maxQty = card.dataset.maxQty ? parseInt(card.dataset.maxQty, 10) : Infinity;
          const discValue = parseFloat(card.dataset.discountValue);
          const discType = card.dataset.discountType;
          const discountCode = card.dataset.discountCode || '';

          let calculatedPrice = currentPrice;
          if (discType === 'percentage') {
            calculatedPrice = currentPrice * (1 - discValue / 100.0);
          } else if (discType === 'fixed_amount') {
            calculatedPrice = Math.max(0, currentPrice - (discValue * 100));
          } else if (discType === 'fixed_price') {
            calculatedPrice = discValue * 100;
          }

          const priceEl = card.querySelector('.wholesale-tier-price');
          if (priceEl) {
            priceEl.innerHTML = formatMoney(calculatedPrice);
            priceEl.dataset.basePrice = currentPrice;
          }

          pricingTiers.push({
            element: card,
            minQty: minQty,
            maxQty: maxQty,
            unitPrice: calculatedPrice,
            discountValue: discValue,
            discountType: discType,
            discountCode: discountCode
          });
        });

        pricingTiers.sort((a, b) => a.minQty - b.minQty);

        const currentQty = qtyInput ? parseInt(qtyInput.value, 10) || 1 : 1;
        let activeTier = pricingTiers[0];

        pricingTiers.forEach(tier => {
          if (currentQty >= tier.minQty && currentQty <= tier.maxQty) {
            activeTier = tier;
          }
        });

        pricingTiers.forEach(tier => {
          if (tier === activeTier) {
            tier.element.classList.add('active');
            const statusText = tier.element.querySelector('.wholesale-tier-status');
            if (statusText) statusText.innerHTML = '<span class="status-dot"></span> Active';
          } else {
            tier.element.classList.remove('active');
            const statusText = tier.element.querySelector('.wholesale-tier-status');
            if (statusText) statusText.innerHTML = '<span class="status-dot"></span> Select';
          }
        });

        if (activeTier.discountCode && activeTier.discountCode !== currentlyAppliedCode) {
          applyDiscountToSession(activeTier.discountCode);
        } else if (!activeTier.discountCode && currentlyAppliedCode !== '') {
          clearDiscountFromSession();
        }

        updateProgressBar(currentQty, pricingTiers);
        updateCalculator(currentQty, currentPrice, activeTier);
      }

      function updateProgressBar(currentQty, pricingTiers) {
        const progressWrapper = container.querySelector('.wholesale-progress-wrapper');
        if (!progressWrapper) return;

        const nextTier = pricingTiers.find(tier => currentQty < tier.minQty);
        
        if (nextTier) {
          progressWrapper.style.display = 'block';
          const neededQty = nextTier.minQty - currentQty;
          const progressPercent = Math.min(100, (currentQty / nextTier.minQty) * 100);

          let savingsDetail = '';
          if (nextTier.discountType === 'percentage') {
            savingsDetail = `${nextTier.discountValue}%`;
          } else {
            savingsDetail = formatMoney(nextTier.discountValue * 100);
          }

          const hintEl = progressWrapper.querySelector('.wholesale-progress-hint');
          if (hintEl) {
            hintEl.innerHTML = `Add <strong>${neededQty} more</strong> to unlock <strong>${savingsDetail} OFF</strong>`;
          }

          const barFill = progressWrapper.querySelector('.wholesale-progress-bar-fill');
          if (barFill) {
            barFill.style.width = `${progressPercent}%`;
          }
        } else {
          progressWrapper.style.display = 'block';
          const hintEl = progressWrapper.querySelector('.wholesale-progress-hint');
          if (hintEl) {
            hintEl.innerHTML = `🎉 You have unlocked our <strong>maximum discount tier!</strong>`;
          }
          const barFill = progressWrapper.querySelector('.wholesale-progress-bar-fill');
          if (barFill) {
            barFill.style.width = `100%`;
          }
        }
      }

      function updateCalculator(qty, originalUnitPrice, activeTier) {
        const displayQty = container.querySelector('#calc-qty-display');
        const unitPriceEl = container.querySelector('#calc-unit-price');
        const originalTotalEl = container.querySelector('#calc-original-total');
        const finalTotalEl = container.querySelector('#calc-final-total');
        const savingsContainer = container.querySelector('#calc-savings-container');
        const savingsAmountEl = container.querySelector('#calc-savings-amount');

        if (displayQty) displayQty.textContent = `${qty} item${qty > 1 ? 's' : ''}`;
        if (unitPriceEl) unitPriceEl.textContent = formatMoney(activeTier.unitPrice);

        const totalOriginal = originalUnitPrice * qty;
        const totalDiscounted = activeTier.unitPrice * qty;
        const savings = totalOriginal - totalDiscounted;

        if (finalTotalEl) finalTotalEl.textContent = formatMoney(totalDiscounted);

        if (savings > 0) {
          if (originalTotalEl) {
            originalTotalEl.textContent = formatMoney(totalOriginal);
            originalTotalEl.style.display = 'inline';
          }
          if (savingsContainer && savingsAmountEl) {
            savingsAmountEl.textContent = formatMoney(savings);
            savingsContainer.style.display = 'flex';
          }
        } else {
          if (originalTotalEl) originalTotalEl.style.display = 'none';
          if (savingsContainer) savingsContainer.style.display = 'none';
        }
      }

      function applyDiscountToSession(code) {
        currentlyAppliedCode = code;
        fetch(`/discount/${code}`).catch(err => console.error(err));
      }

      function clearDiscountFromSession() {
        currentlyAppliedCode = '';
        fetch(`/discount/CLEAR`).catch(err => console.error(err));
      }

      if (qtyInput) {
        qtyInput.addEventListener('change', updateWidget);
        qtyInput.addEventListener('input', updateWidget);
        
        const quantityButtons = document.querySelectorAll('.quantity__button, .qty-btn, .quantity-selector button');
        quantityButtons.forEach(btn => {
          btn.addEventListener('click', function() {
            setTimeout(updateWidget, 50);
          });
        });
      }

      const variantSelects = document.querySelectorAll(variantInputSelectors.join(','));
      variantSelects.forEach(select => {
        select.addEventListener('change', updateWidget);
      });

      document.addEventListener('change', function(e) {
        if (e.target.matches('variant-selects select') || e.target.matches('variant-radios input')) {
          setTimeout(updateWidget, 50);
        }
      });

      let lastUrl = window.location.href;
      const urlObserver = new MutationObserver(() => {
        if (window.location.href !== lastUrl) {
          lastUrl = window.location.href;
          updateWidget();
        }
      });
      urlObserver.observe(document.head, { subtree: true, childList: true });

      const tierCards = container.querySelectorAll('.wholesale-tier-card');
      tierCards.forEach(card => {
        card.addEventListener('click', function() {
          if (!qtyInput) return;
          qtyInput.value = parseInt(this.dataset.minQty, 10);
          qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
          updateWidget();
        });
      });

      updateWidget();
    }

    function formatMoney(cents) {
      const amount = (cents / 100.0).toFixed(2);
      const shopCurrencySymbol = '{{ cart.currency.symbol }}' || '$';
      return `${shopCurrencySymbol}${amount}`;
    }
  })();
  </script>

  <style>
    .wholesale-widget-container-embed {
      background: var(--gradient-background, #ffffff);
      color: rgba(var(--color-foreground), 0.75);
      border: 1px solid rgba(var(--color-foreground), 0.08);
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
      margin: 1.5rem 0;
      width: 100%;
      box-sizing: border-box;
      font-family: inherit;
    }

    .wholesale-header { margin-bottom: 1.25rem; }
    .wholesale-title-wrapper {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-bottom: 0.25rem;
    }
    .wholesale-badge-glow {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
      font-size: 0.725rem;
      font-weight: 700;
      padding: 0.2rem 0.5rem;
      border-radius: 9999px;
      border: 1px solid rgba(16, 185, 129, 0.2);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      animation: wsPulse 2s infinite;
    }
    @keyframes wsPulse {
      0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
      70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
      100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }
    .wholesale-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin: 0;
      color: inherit;
    }
    .wholesale-subheading {
      font-size: 0.825rem;
      color: rgba(var(--color-foreground), 0.6);
      margin: 0.25rem 0 0 0;
    }

    .wholesale-tiers-grid {
      display: grid;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    }

    .wholesale-tier-card {
      background: transparent;
      border: 1px solid rgba(var(--color-foreground), 0.08);
      border-radius: 8px;
      padding: 0.8rem;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .wholesale-tier-card:hover {
      border-color: #10b981;
      transform: translateY(-1px);
    }

    .wholesale-tier-card.active {
      border-color: #10b981;
      background: rgba(16, 185, 129, 0.02);
      box-shadow: 0 0 0 1px #10b981;
    }

    .wholesale-tier-qty { font-size: 0.8rem; font-weight: 600; }
    .wholesale-tier-price { font-size: 1.05rem; font-weight: 700; margin: 0.2rem 0; color: inherit; }
    
    .wholesale-tier-discount {
      font-size: 0.7rem;
      font-weight: 600;
      color: #10b981;
      background: rgba(16, 185, 129, 0.08);
      padding: 0.1rem 0.35rem;
      border-radius: 4px;
      align-self: flex-start;
    }

    .wholesale-tier-status {
      font-size: 0.65rem;
      color: rgba(var(--color-foreground), 0.5);
      margin-top: 0.4rem;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .status-dot { width: 5px; height: 5px; border-radius: 50%; background: #d1d5db; display: inline-block; }
    .wholesale-tier-card.active .status-dot { background: #10b981; }
    .wholesale-tier-card.active .wholesale-tier-status { color: #10b981; font-weight: 600; }

    .wholesale-progress-wrapper {
      background: rgba(var(--color-foreground), 0.02);
      border: 1px solid rgba(var(--color-foreground), 0.08);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      margin-bottom: 1.25rem;
    }
    .wholesale-progress-text {
      display: flex;
      justify-content: space-between;
      font-size: 0.725rem;
      font-weight: 500;
      color: rgba(var(--color-foreground), 0.6);
      margin-bottom: 0.4rem;
    }
    .wholesale-progress-hint { color: inherit; font-weight: 600; }
    .wholesale-progress-bar-bg { height: 5px; background: rgba(var(--color-foreground), 0.08); border-radius: 9999px; overflow: hidden; }
    .wholesale-progress-bar-fill { height: 100%; background: #10b981; border-radius: 9999px; transition: width 0.3s ease; }

    .wholesale-calculator {
      background: rgba(var(--color-foreground), 0.02);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      border: 1px dashed rgba(var(--color-foreground), 0.08);
    }
    .calc-row { display: flex; justify-content: space-between; font-size: 0.825rem; margin-bottom: 0.5rem; color: rgba(var(--color-foreground), 0.6); }
    .calc-row:last-of-type { margin-bottom: 0; }
    .calc-row.total-row { border-top: 1px solid rgba(var(--color-foreground), 0.08); padding-top: 0.5rem; margin-top: 0.5rem; margin-bottom: 0.5rem; }
    .calc-val { font-weight: 600; color: inherit; }
    .calc-total-wrapper { display: flex; flex-direction: column; align-items: flex-end; }
    .price-original { font-size: 0.725rem; color: rgba(var(--color-foreground), 0.5); text-decoration: line-through; }
    .price-final { font-size: 1rem; font-weight: 700; color: #10b981; }
    
    .calc-savings-badge {
      background: rgba(16, 185, 129, 0.06);
      color: #065f46;
      border: 1px solid rgba(16, 185, 129, 0.12);
      border-radius: 6px;
      padding: 0.45rem 0.65rem;
      font-size: 0.775rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 0.65rem;
    }
    .savings-icon { width: 14px; height: 14px; color: #10b981; }

    .wholesale-footer-note { font-size: 0.675rem; color: rgba(var(--color-foreground), 0.5); text-align: center; }

    /* Logged out */
    .wholesale-card--logged-out { text-align: center; padding: 2rem 1.25rem; border: 1.5px dashed rgba(var(--color-foreground), 0.08); }
    .lock-icon-wrapper {
      background: rgba(var(--color-foreground), 0.04);
      width: 44px; height: 44px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 0.75rem auto; color: rgba(var(--color-foreground), 0.5);
    }
    .lock-icon { width: 20px; height: 20px; }
    .wholesale-logged-out-title { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.4rem 0; color: inherit; }
    .wholesale-logged-out-text { font-size: 0.8rem; color: rgba(var(--color-foreground), 0.6); line-height: 1.4; max-width: 300px; margin: 0 auto 1.25rem auto; }
    .wholesale-login-btn {
      display: inline-block; background: rgba(var(--color-foreground), 0.9); color: white; text-decoration: none;
      font-size: 0.8rem; font-weight: 600; padding: 0.6rem 1.5rem; border-radius: 6px;
    }
    .wholesale-login-btn:hover { opacity: 0.9; }
    .wholesale-register-prompt { margin-top: 0.85rem; font-size: 0.725rem; color: rgba(var(--color-foreground), 0.5); }
    .wholesale-register-prompt a { color: inherit; font-weight: 600; text-decoration: underline; }
  </style>
{% endif %}

{% schema %}
{
  "name": "Wholesale Auto-Pricing",
  "target": "body",
  "settings": [
    {
