{% comment %}
  Free Shipping Progress Tracker (App Embed version with Auto-Injection)
{% endcomment %}

{{ 'storefront-suite.css' | asset_url | stylesheet_tag }}

<div class="free-shipping-tracker-container" id="fs-tracker-{{ block.id }}" style="display: none;">
  <div class="fs-tracker-content">
    <p class="fs-tracker-message" id="fs-message-{{ block.id }}">
      Calculating...
    </p>
    <div class="fs-progress-bar-bg">
      <div class="fs-progress-bar-fill" id="fs-fill-{{ block.id }}" style="width: 0%;"></div>
    </div>
  </div>
</div>

<script>
  (function() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFreeShippingTracker);
    } else {
      initFreeShippingTracker();
    }

    function initFreeShippingTracker() {
      console.log("[Shipping Tracker] Initializing...");
      
      const container = document.getElementById('fs-tracker-{{ block.id }}');
      const messageEl = document.getElementById('fs-message-{{ block.id }}');
      const fillEl = document.getElementById('fs-fill-{{ block.id }}');
      
      if (!container || !messageEl || !fillEl) {
        console.error("[Shipping Tracker] Required DOM elements not found!");
        return;
      }

      // Safe threshold parsing
      let thresholdSetting = '{{ block.settings.shipping_threshold }}';
      let parsedThreshold = parseFloat(thresholdSetting);
      if (isNaN(parsedThreshold) || parsedThreshold <= 0) {
        parsedThreshold = 75; // Fallback to 75
      }
      const threshold = parsedThreshold * 100; // Convert to cents
      
      const position = '{{ block.settings.position | default: "top_banner" }}';
      container.className = `free-shipping-tracker-container fs-pos-${position}`;

      const barColor = '{{ block.settings.bar_color | default: "#10b981" }}';
      fillEl.style.backgroundColor = barColor;

      function updateTracker() {
        fetch('/cart.js')
          .then(res => res.json())
          .then(cart => {
            const total = cart.total_price;
            console.log("[Shipping Tracker] Current Cart Subtotal:", total, "cents. Threshold is:", threshold, "cents.");
            
            if (total === 0) {
              container.style.display = 'none';
              return;
            }

            container.style.display = 'block';

            if (total >= threshold) {
              fillEl.style.width = '100%';
              messageEl.innerHTML = '{{ block.settings.goal_reached_text | default: "🎉 You have unlocked Free Shipping!" | escape }}';
            } else {
              const remaining = threshold - total;
              const percent = Math.min(100, (total / threshold) * 100);
              fillEl.style.width = `${percent}%`;

              const remainingFormatted = formatFSMoney(remaining);
              const progressText = '{{ block.settings.progress_text | default: "You are [amount] away from Free Shipping!" }}';
              
              messageEl.innerHTML = progressText.replace('[amount]', `<strong>${remainingFormatted}</strong>`);
            }
          })
          .catch(err => console.error('[Shipping Tracker] Error loading cart', err));
      }

      function formatFSMoney(cents) {
        const amount = (cents / 100.0).toFixed(2);
        const shopCurrencySymbol = '{{ cart.currency.symbol }}' || '$';
        return `${shopCurrencySymbol}${amount}`;
      }

      // Initial run
      updateTracker();

      // 1. Intercept Fetch API requests
      const nativeFetch = window.fetch;
      window.fetch = function() {
        return nativeFetch.apply(this, arguments).then(response => {
          const url = arguments[0];
          if (typeof url === 'string' && (url.includes('/cart/add') || url.includes('/cart/change') || url.includes('/cart/clear') || url.includes('/cart/update'))) {
            console.log("[Shipping Tracker] Cart mutation detected via fetch(). Updating...");
            setTimeout(updateTracker, 600);
          }
          return response;
        });
      };

      // 2. Intercept XMLHttpRequests (handles jQuery, AJAX drawers, and older themes)
      const nativeOpen = XMLHttpRequest.prototype.open;
      XMLHttpRequest.prototype.open = function(method, url) {
        this.addEventListener('load', function() {
          if (typeof url === 'string' && (url.includes('/cart/add') || url.includes('/cart/change') || url.includes('/cart/clear') || url.includes('/cart/update'))) {
            console.log("[Shipping Tracker] Cart mutation detected via XHR. Updating...");
            setTimeout(updateTracker, 600);
          }
        });
        return nativeOpen.apply(this, arguments);
      };
    }
  })();
  </script>

{% schema %}
{
  "name": "Free Shipping Progress",
  "target": "body",
  "settings": [
    {
      "type": "number",
      "id": "shipping_threshold",
      "label": "Shipping Goal Amount",
      "default": 75
    },
    {
      "type": "text",
      "id": "progress_text",
      "label": "Goal Progress Message",
      "default": "You are [amount] away from Free Shipping!"
    },
    {
      "type": "text",
      "id": "goal_reached_text",
      "label": "Goal Reached Message",
      "default": "🎉 You have unlocked Free Shipping!"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Bar Position",
      "options": [
        { "value": "top_banner", "label": "Sticky Top Header" },
        { "value": "bottom_floating", "label": "Floating Bottom Card" }
      ],
      "default": "top_banner"
    },
    {
      "type": "color",
      "id": "bar_color",
      "label": "Progress Bar Color",
      "default": "#10b981"
    }
  ]
}
{% endschema %}
