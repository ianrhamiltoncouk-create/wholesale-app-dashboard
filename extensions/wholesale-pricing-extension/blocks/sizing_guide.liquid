{% comment %}
  Sizing Guide Link & Popup Chart (App Block version)
  Adds a size chart link next to size variant options and opens a measurement guide modal.
  Can be placed anywhere on the product details page.
{% endcomment %}

<div class="sizing-guide-wrapper-block" id="sg-{{ block.id }}">
  <button type="button" class="sizing-guide-trigger-link" onclick="openSizingGuideModal('{{ block.id }}')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ruler-icon">
      <path d="M21.3 8.24l-3-3a1.41 1.41 0 0 0-2 0L3 18.57V21h2.4l15.9-15.9a1.41 1.41 0 0 0 0-1.86z"></path>
      <line x1="16" y1="8" x2="18" y2="10"></line>
      <line x1="12" y1="12" x2="14" y2="14"></line>
      <line x1="8" y1="16" x2="10" y2="18"></line>
    </svg>
    <span>{{ block.settings.link_text | default: "Size Guide" | escape }}</span>
  </button>

  <!-- Modal Backdrop & Box -->
  <div class="sizing-modal-backdrop" id="sg-modal-{{ block.id }}">
    <div class="sizing-modal-card">
      <button type="button" class="sizing-modal-close" onclick="closeSizingGuideModal('{{ block.id }}')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="close-icon">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="sizing-modal-body">
        <h3 class="sizing-modal-title">{{ block.settings.chart_title | default: "Sizing Chart" | escape }}</h3>
        
        <div class="sizing-table-wrapper">
          <table class="sizing-chart-table">
            <thead>
              <tr id="sg-headers-{{ block.id }}">
                <!-- Populated dynamically by JS -->
              </tr>
            </thead>
            <tbody id="sg-rows-{{ block.id }}">
              <!-- Populated dynamically by JS -->
            </tbody>
          </table>
        </div>

        {% if block.settings.text_below_table != blank %}
          <p class="sizing-modal-footer-note">{{ block.settings.text_below_table | escape }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .sizing-guide-wrapper-block {
    display: inline-block;
    margin: 0.5rem 0;
    font-family: inherit;
  }

  .sizing-guide-trigger-link {
    background: transparent;
    border: none;
    padding: 0.25rem 0;
    color: rgba(var(--color-foreground), 0.7);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.25s ease;
  }
  .sizing-guide-trigger-link:hover {
    color: #10b981;
  }
  .ruler-icon { width: 14px; height: 14px; }

  /* Sizing Guide Modal */
  .sizing-modal-backdrop {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 999999;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
  }
  .sizing-modal-backdrop.is-open { opacity: 1; pointer-events: auto; }

  .sizing-modal-card {
    background: var(--gradient-background, #ffffff);
    color: rgba(var(--color-foreground), 0.75);
    width: 90%; max-width: 550px;
    border-radius: 12px;
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
    position: relative; overflow: hidden;
    transform: scale(0.95); transition: transform 0.3s ease;
    border: 1px solid rgba(var(--color-foreground), 0.08);
  }
  .sizing-modal-backdrop.is-open .sizing-modal-card { transform: scale(1); }

  .sizing-modal-close {
    position: absolute; top: 1rem; right: 1rem;
    background: transparent; border: none;
    color: rgba(var(--color-foreground), 0.4); cursor: pointer;
    z-index: 10; padding: 0.25rem; border-radius: 50%;
  }
  .sizing-modal-close:hover { color: rgba(var(--color-foreground), 0.9); background: rgba(0,0,0,0.05); }
  .sizing-modal-close .close-icon { width: 16px; height: 16px; }

  .sizing-modal-body { padding: 2rem; }
  .sizing-modal-title { font-size: 1.15rem; font-weight: 800; color: inherit; margin: 0 0 1.25rem 0; text-align: center; }

  .sizing-table-wrapper {
    overflow-x: auto;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 8px;
    margin-bottom: 1rem;
  }
  .sizing-chart-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    text-align: left;
  }
  .sizing-chart-table th, .sizing-chart-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.06);
  }
  .sizing-chart-table th {
    background: rgba(var(--color-foreground), 0.02);
    font-weight: 700;
  }
  .sizing-chart-table tr:last-child td {
    border-bottom: none;
  }

  .sizing-modal-footer-note { font-size: 0.725rem; color: rgba(var(--color-foreground), 0.5); text-align: center; margin: 0.5rem 0 0 0; }
</style>

<script>
  function openSizingGuideModal(blockId) {
    const backdrop = document.getElementById(`sg-modal-${blockId}`);
    if (backdrop) backdrop.classList.add('is-open');
  }

  function closeSizingGuideModal(blockId) {
    const backdrop = document.getElementById(`sg-modal-${blockId}`);
    if (backdrop) backdrop.classList.remove('is-open');
  }

  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      renderSizingChart();
    });

    function renderSizingChart() {
      const headersContainer = document.getElementById('sg-headers-{{ block.id }}');
      const rowsContainer = document.getElementById('sg-rows-{{ block.id }}');
      
      if (!headersContainer || !rowsContainer) return;

      // 1. Populate Headers
      const headersStr = '{{ block.settings.chart_table_headers | default: "Size, Chest (in), Waist (in)" }}';
      const headers = headersStr.split(',');
      headersContainer.innerHTML = headers.map(h => `<th>${h.trim()}</th>`).join('');

      // 2. Populate Rows
      const rowsStr = `{{ block.settings.chart_table_rows | replace: "\r", "" }}`;
      const lines = rowsStr.split('\n');
      
      let rowsHtml = '';
      lines.forEach(line => {
        if (line.trim() !== '') {
          const cells = line.split(':');
          rowsHtml += `<tr>${cells.map(c => `<td>${c.trim()}</td>`).join('')}</tr>`;
        }
      });
      rowsContainer.innerHTML = rowsHtml;
    }
  })();
</script>

{% schema %}
{
  "name": "Sizing Guide Link",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text label",
      "default": "📏 Size Guide"
    },
    {
      "type": "text",
      "id": "chart_title",
      "label": "Modal Chart Title",
      "default": "Sizing Chart"
    },
    {
      "type": "text",
      "id": "chart_table_headers",
      "label": "Table Headers (comma-separated)",
      "default": "Size, Chest (in), Waist (in), Hips (in)"
    },
    {
      "type": "textarea",
      "id": "chart_table_rows",
      "label": "Table Rows (colon-separated cells, new line per row)",
      "default": "S: 34-36: 28-30: 34-36\nM: 38-40: 32-34: 38-40\nL: 42-44: 36-38: 42-44\nXL: 46-48: 40-42: 46-48",
      "info": "Format cell values separated by colons (:), one row per line. Example: S: 34-36: 28-30"
    },
    {
      "type": "textarea",
      "id": "text_below_table",
      "label": "Footer Note Below Table",
      "default": "Measurements refer to body size, not garment dimensions."
    }
  ],
  "presets": [
    {
      "name": "Sizing Guide Link"
    }
  ]
}
{% endschema %}
