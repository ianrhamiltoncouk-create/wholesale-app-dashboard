{% comment %}
  Sizing Guide Link & Popup Chart (App Block version)
{% endcomment %}

{{ 'storefront-suite.css' | asset_url | stylesheet_tag }}

<div class="sizing-guide-wrapper-block" id="sg-{{ block.id }}">
  <button type="button" class="sizing-guide-trigger-link" onclick="openSizingGuideModal('{{ block.id }}')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ruler-icon">
      <path d="M21.3 8.24l-3-3a1.41 1.41 0 0 0-2 0L3 18.57V21h2.4l15.9-15.9a1.41 1.41 0 0 0 0-1.86z"></path>
      <line x1="16" y1="8" x2="18" y2="10"></line>
      <line x1="12" y1="12" x2="14" y2="14"></line>
      <line x1="8" y1="16" x2="10" y2="18"></line>
    </svg>
    <span>{{ block.settings.link_text | default: "Size Guide" | escape }}</span>
  </button>

  <div class="sizing-modal-backdrop" id="sg-modal-{{ block.id }}">
    <div class="sizing-modal-card">
      <button type="button" class="sizing-modal-close" onclick="closeSizingGuideModal('{{ block.id }}')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="close-icon">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="sizing-modal-body">
        <h3 class="sizing-modal-title">{{ block.settings.chart_title | default: "Sizing Chart" | escape }}</h3>
        
        <div class="sizing-table-wrapper">
          <table class="sizing-chart-table">
            <thead>
              <tr id="sg-headers-{{ block.id }}">
              </tr>
            </thead>
            <tbody id="sg-rows-{{ block.id }}">
            </tbody>
          </table>
        </div>

        {% if block.settings.text_below_table != blank %}
          <p class="sizing-modal-footer-note">{{ block.settings.text_below_table | escape }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  function openSizingGuideModal(blockId) {
    const backdrop = document.getElementById(`sg-modal-${blockId}`);
    if (backdrop) backdrop.classList.add('is-open');
  }

  function closeSizingGuideModal(blockId) {
    const backdrop = document.getElementById(`sg-modal-${blockId}`);
    if (backdrop) backdrop.classList.remove('is-open');
  }

  (function() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', renderSizingChart);
    } else {
      renderSizingChart();
    }

    function renderSizingChart() {
      const headersContainer = document.getElementById('sg-headers-{{ block.id }}');
      const rowsContainer = document.getElementById('sg-rows-{{ block.id }}');
      
      if (!headersContainer || !rowsContainer) return;

      const headersStr = '{{ block.settings.chart_table_headers | default: "Size, Chest (in), Waist (in)" }}';
      const headers = headersStr.split(',');
      headersContainer.innerHTML = headers.map(h => `<th>${h.trim()}</th>`).join('');

      const rowsStr = `{{ block.settings.chart_table_rows | replace: "\r", "" }}`;
      const lines = rowsStr.split('\n');
      
      let rowsHtml = '';
      lines.forEach(line => {
        if (line.trim() !== '') {
          const cells = line.split(':');
          rowsHtml += `<tr>${cells.map(c => `<td>${c.trim()}</td>`).join('')}</tr>`;
        }
      });
      rowsContainer.innerHTML = rowsHtml;
    }
  })();
</script>

{% schema %}
{
  "name": "Sizing Guide Link",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text label",
      "default": "📏 Size Guide"
    },
    {
      "type": "text",
      "id": "chart_title",
      "label": "Modal Chart Title",
      "default": "Sizing Chart"
    },
    {
      "type": "text",
      "id": "chart_table_headers",
      "label": "Table Headers (comma-separated)",
      "default": "Size, Chest (in), Waist (in), Hips (in)"
    },
    {
      "type": "textarea",
      "id": "chart_table_rows",
      "label": "Table Rows (colon-separated cells, new line per row)",
      "default": "S: 34-36: 28-30: 34-36\nM: 38-40: 32-34: 38-40\nL: 42-44: 36-38: 42-44\nXL: 46-48: 40-42: 46-48",
      "info": "Format cell values separated by colons (:), one row per line."
    },
    {
      "type": "textarea",
      "id": "text_below_table",
      "label": "Footer Note Below Table",
      "default": "Measurements refer to body size, not garment dimensions."
    }
  ]
}
{% endschema %}
