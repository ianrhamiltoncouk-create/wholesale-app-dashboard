{% comment %}
  Related Products Upsell Slider (App Block version)
{% endcomment %}

{{ 'storefront-suite.css' | asset_url | stylesheet_tag }}

<div class="related-products-slider-block" id="rp-{{ block.id }}" style="display: none;">
  <h3 class="rp-slider-title">{{ block.settings.heading | default: "You May Also Like" | escape }}</h3>
  
  <div class="rp-products-grid" id="rp-grid-{{ block.id }}">
  </div>
</div>

<script>
  (function() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadRelatedRecommendations);
    } else {
      loadRelatedRecommendations();
    }

    function loadRelatedRecommendations() {
      const container = document.getElementById('rp-{{ block.id }}');
      const grid = document.getElementById('rp-grid-{{ block.id }}');
      
      if (!container || !grid) return;

      const productId = '{{ product.id }}';
      const limit = parseInt('{{ block.settings.limit | default: 4 }}', 10);
      
      fetch(`/recommendations/products.json?product_id=${productId}&limit=${limit}`)
        .then(response => response.json())
        .then(data => {
          if (data.products && data.products.length > 0) {
            container.style.display = 'block';
            let html = '';
            
            data.products.forEach(prod => {
              const formattedPrice = formatRPMoney(prod.price);
              const imgUrl = prod.featured_image ? prod.featured_image : 'https://cdn.shopify.com/s/images/admin/no-image-large.gif';

              html += `
                <a href="${prod.url}" class="rp-card">
                  <div class="rp-card-image-wrapper">
                    <img class="rp-card-img" src="${imgUrl}" alt="${prod.title}">
                  </div>
                  <h4 class="rp-card-title">${prod.title}</h4>
                  <span class="rp-card-price">${formattedPrice}</span>
                </a>
              `;
            });
            grid.innerHTML = html;
          }
        })
        .catch(err => {
          console.error('Error fetching Shopify recommendations API', err);
        });
    }

    function formatRPMoney(cents) {
      const amount = (cents / 100.0).toFixed(2);
      const shopCurrencySymbol = '{{ cart.currency.symbol }}' || '$';
      return `${shopCurrencySymbol}${amount}`;
    }
  })();
</script>

{% schema %}
{
  "name": "Related Products Slider",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "You May Also Like"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Max Recommendations to Show",
      "default": 4
    }
  ]
}
{% endschema %}
